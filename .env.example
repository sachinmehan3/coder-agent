# =====================================================================
# Coder-Agent Configuration Template
# 
# Instructions:
# 1. Copy this file to `.env`
# 2. Fill in the API keys for the AI providers you want to use
# 3. The agent will automatically detect which key to use based 
#    on the --model argument passed to main.py
# =====================================================================

# Primary Model Providers
MISTRAL_API_KEY=your_mistral_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Tool Integrations
# Required for the web_search tool to function
TAVILY_API_KEY=your_tavily_api_key_here

